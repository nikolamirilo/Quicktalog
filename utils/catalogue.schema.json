{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ServiceCatalogue",
  "definitions": {
    "ServiceCatalogue": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "created_by": {
          "type": "string"
        },
        "theme": {
          "type": "string"
        },
        "logo": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "currency": {
          "type": "string"
        },
        "contact": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "value"
            ],
            "additionalProperties": false
          }
        },
        "subtitle": {
          "type": "string"
        },
        "services": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "layout": {
                "type": "string"
              },
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/Service"
                }
              }
            },
            "required": [
              "layout",
              "items"
            ],
            "additionalProperties": false
          }
        },
        "address": {
          "type": "string"
        },
        "partners": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Partner"
          }
        },
        "legal": {
          "$ref": "#/definitions/Legal"
        },
        "configuration": {
          "$ref": "#/definitions/Configuration"
        },
        "created_at": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "created_by",
        "theme",
        "title",
        "currency",
        "services",
        "created_at",
        "updated_at"
      ],
      "additionalProperties": false
    },
    "Service": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "price": {
          "type": "number"
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "image",
        "price",
        "description"
      ],
      "additionalProperties": false
    },
    "Partner": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "url",
        "icon"
      ],
      "additionalProperties": false
    },
    "Legal": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "terms_and_conditions": {
          "type": "string"
        },
        "privacy_policy": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "terms_and_conditions",
        "privacy_policy"
      ],
      "additionalProperties": false
    },
    "Configuration": {
      "type": "object",
      "properties": {
        "emailButtonNavbar": {
          "type": "boolean"
        },
        "ctaNavbar": {
          "type": "object",
          "properties": {
            "label": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "label",
            "url"
          ],
          "additionalProperties": false
        },
        "ctaFooter": {
          "type": "object",
          "properties": {
            "label": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "label",
            "url"
          ],
          "additionalProperties": false
        },
        "newsletter": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "enabled",
            "url"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}