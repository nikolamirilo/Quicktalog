{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ServiceCatalogue",
  "definitions": {
    "ServiceCatalogue": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "created_by": {
          "type": "string"
        },
        "theme": {
          "$ref": "#/definitions/ThemeVariant"
        },
        "logo": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "currency": {
          "type": "string"
        },
        "contact": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "value"
            ],
            "additionalProperties": false
          }
        },
        "subtitle": {
          "type": "string"
        },
        "services": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/ServicesCategory"
          }
        },
        "address": {
          "type": "string"
        },
        "partners": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Partner"
          }
        },
        "legal": {
          "$ref": "#/definitions/Legal"
        },
        "configuration": {
          "$ref": "#/definitions/Configuration"
        }
      },
      "required": [
        "id",
        "name",
        "created_by",
        "theme",
        "title",
        "currency",
        "services"
      ],
      "additionalProperties": false
    },
    "ThemeVariant": {
      "type": "string",
      "enum": [
        "theme-elegant",
        "theme-luxury",
        "theme-modern",
        "theme-organic",
        "theme-creative"
      ]
    },
    "ServicesCategory": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "layout": {
          "$ref": "#/definitions/LayoutVariant"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ServicesItem"
          }
        }
      },
      "required": [
        "name",
        "layout",
        "items"
      ],
      "additionalProperties": false
    },
    "LayoutVariant": {
      "type": "string",
      "enum": [
        "variant_1",
        "variant_2",
        "variant_3",
        "variant_4"
      ]
    },
    "ServicesItem": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "price": {
          "type": "number"
        },
        "image": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "description",
        "price",
        "image"
      ],
      "additionalProperties": false
    },
    "Partner": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "url",
        "icon"
      ],
      "additionalProperties": false
    },
    "Legal": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "terms_and_conditions": {
          "type": "string"
        },
        "privacy_policy": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "terms_and_conditions",
        "privacy_policy"
      ],
      "additionalProperties": false
    },
    "Configuration": {
      "type": "object",
      "properties": {
        "emailButtonNavbar": {
          "type": "boolean"
        },
        "ctaNavbar": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "label": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "enabled",
            "label",
            "url"
          ],
          "additionalProperties": false
        },
        "ctaFooter": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "label": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "enabled",
            "label",
            "url"
          ],
          "additionalProperties": false
        },
        "newsletter": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "enabled",
            "url"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}